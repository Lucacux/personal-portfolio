---
import Icon from "./Icon.astro";

const socials = [
  { name: "github" as const,   href: "https://github.com/Lucacux", label: "GitHub" },
  { name: "linkedin" as const, href: "https://www.linkedin.com/in/luca-santiago-lombardo-038a97353/", label: "LinkedIn" },
  { name: "mail" as const,     href: "mailto:lucalombardi336@gmail.com", label: "Email" },
];
---

<div class="navbar-outer">
  <nav class="wrap navbar-inner">
    <a class="logo" href="/">luca@lombardo:~$<span class="typed-role" id="typed-role"></span><span class="cursor" aria-hidden="true"></span></a>
    <div class="nav-right">
      {socials.map((s) => (
        <a class="icon-link" href={s.href} aria-label={s.label} target="_blank" rel="noopener">
          <Icon name={s.name} />
        </a>
      ))}
      <button class="icon-link" id="theme-toggle" aria-label="Toggle theme" type="button">
        <span class="icon-sun"><Icon name="sun" /></span>
        <span class="icon-moon"><Icon name="moon" /></span>
      </button>
    </div>
  </nav>
</div>


<style>
  .navbar-outer {
    position: sticky;
    top: 0;
    z-index: 10;
    width: 100%;
    background: rgba(241, 240, 236, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  :global([data-theme="dark"]) .navbar-outer {
    background: rgba(22, 24, 27, 0.82);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 22px;
    gap: 16px;
    flex-wrap: wrap;
    row-gap: 10px;
  }
  .logo { font-family: var(--mono); font-size: 16px; font-weight: 600; white-space: nowrap; overflow: hidden; }
  .cursor {
    display: inline-block;
    width: 8px; height: 16px;
    background: var(--accent);
    margin-left: 2px; vertical-align: -3px;
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .nav-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

  .icon-link {
    width: 34px; height: 34px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    color: var(--text);
    cursor: pointer; background: transparent; flex-shrink: 0;
  }
  .icon-link :global(svg) { width: 16px; height: 16px; }
  .icon-link:hover { border-color: var(--accent); color: var(--accent); }

  .icon-moon { display: none; }
  :global([data-theme="dark"]) .icon-sun  { display: none; }
  :global([data-theme="dark"]) .icon-moon { display: flex; }

  .typed-role { font-weight: 400; color: var(--text-muted); font-size: 13px; }

  @media (max-width: 480px) {
    .navbar-inner { padding-block: 10px; flex-wrap: nowrap; }
    .logo { font-size: 13px; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    .typed-role { display: none; }
    .nav-right { gap: 2px; }
    .icon-link { width: 30px; height: 30px; border: none; }
    .icon-link :global(svg) { width: 14px; height: 14px; }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById("theme-toggle");
    if (toggle) {
      toggle.addEventListener("click", function () {
        var html = document.documentElement;
        var next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
      });
    }

    // Typewriter
    var el = document.getElementById("typed-role");
    if (!el) return;
    var text = " IAM Assoc. @ EY GDS";
    var i = 0;
    setTimeout(function type() {
      if (i < text.length) {
        el.textContent += text[i];
        i++;
        setTimeout(type, 55 + Math.random() * 40);
      }
    }, 2500);
  })();
</script>
