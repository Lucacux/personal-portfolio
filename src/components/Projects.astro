---
import { getCollection } from "astro:content";

const entries = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);

// Resolve thumbnail filenames to processed image URLs
const imgModules = import.meta.glob("../images/*", { eager: true, query: "?url", import: "default" }) as Record<string, string>;
function thumbUrl(filename?: string) {
  if (!filename) return undefined;
  const match = Object.entries(imgModules).find(([path]) => path.endsWith("/" + filename));
  return match?.[1];
}
function imgUrl(filename: string) {
  const match = Object.entries(imgModules).find(([path]) => path.endsWith("/" + filename));
  return match?.[1];
}
// Tag → logo map (shared visual language with the case study)
const tagLogos: Record<string, string | undefined> = {
  "Peppermint": imgUrl("peppermint-logo.svg"),
  "Ubuntu": imgUrl("ubuntu-original.svg"),
  "Debian": imgUrl("debian-original.svg"),
  "Arch Linux": imgUrl("archlinux-original.svg"),
  "Samba": imgUrl("samba-logo.svg"),
  "Cloudflare Tunnel": imgUrl("Cloudflare_Logo.svg"),
  "SSH": imgUrl("ssh-logo.svg"),
  "Docker": imgUrl("docker-original.svg"),
  "Jellyfin": imgUrl("jellyfin-logo.svg"),
  "OpenWrt": imgUrl("OpenWrt_Logo.svg"),
  "Firewall": imgUrl("firewall.svg"),
  "VLANs": imgUrl("router.svg"),
  "DNS-over-HTTPS": imgUrl("dns.svg"),
  "SQM / CAKE": imgUrl("qos.svg"),
  "zram": imgUrl("ram-memory.svg"),
};

// OpenWrt wordmark for the OpenWrt card title (light + dark variants).
const openwrtLogo = imgUrl("OpenWrt_Logo.svg");
const openwrtLogoDark = imgUrl("OpenWrt_Logo-dark.svg");
---

<div class="section-outer" id="projects">
  <div class="dot-pattern fade-r" style="top:24px;left:0;"></div>
  <div class="dot-pattern fade-l" style="bottom:40px;right:0;"></div>
  <div class="wrap section-inner reveal">
    <div class="section-head">
      <h2>Featured Projects</h2>
      <span class="count">ordered by relevance</span>
    </div>

    <div class="timeline">
      {entries.map((p, i) => (
        <div class="tl-item">
          <div class="tl-marker">{String(i + 1).padStart(2, "0")}</div>
          <a class="project-card" href={`/projects/${p.id}/`}>
            <div>
              <h3>{p.id === "openwrt" ? (
                <span class="title-with-logo">
                  <img class="title-logo logo-light" src={openwrtLogo} alt="OpenWrt" />
                  <img class="title-logo logo-dark" src={openwrtLogoDark} alt="OpenWrt" />
                  <span>router lab</span>
                </span>
              ) : p.data.title}</h3>
              <p class="pitch">{p.data.pitch}</p>
              <div class="tag-row">
                {p.data.tags.map((t) => (
                  <span class="tag">
                    {tagLogos[t] && <img class="tag-logo" src={tagLogos[t]} alt="" loading="lazy" />}
                    {t}
                  </span>
                ))}
              </div>
              <span class="project-link">view case study →</span>
            </div>
            {thumbUrl(p.data.thumbnail)
              ? <div class="thumb has-img"><img src={thumbUrl(p.data.thumbnail)} alt={p.data.title} loading="lazy" /></div>
              : <div class="thumb">photo / screenshot</div>
            }
          </a>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .timeline { position: relative; }
  .tl-item { display: grid; grid-template-columns: 40px minmax(0, 1fr); gap: 16px; position: relative; }
  .tl-item:last-child .tl-marker::after { display: none; }
  .tl-marker { font-family: var(--mono); font-size: 13px; color: var(--text-muted); padding-top: 26px; position: relative; }
  .tl-marker::after { content: ""; position: absolute; top: 46px; bottom: -40px; left: 50%; width: 1px; background: var(--border); }
  .project-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; padding: 26px 28px; display: grid; grid-template-columns: minmax(0, 1fr) 200px; gap: 24px; align-items: center; margin-bottom: 40px; transition: border-color .15s ease; }
  .project-card { transition: border-color .15s ease, transform .2s ease, box-shadow .2s ease; }
  .project-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .project-card .tag-row { display: flex; gap: 8px; flex-wrap: wrap; margin: 12px 0 14px; }
  .tag { display: inline-flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 11px; color: var(--accent); background: var(--accent-soft); padding: 4px 9px; border-radius: 3px; }
  .tag-logo { width: 14px; height: 14px; object-fit: contain; }
  .project-card h3 { font-size: 19px; font-weight: 600; margin-bottom: 2px; }
  .title-with-logo { display: inline-flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .title-logo { height: 1.15em; width: auto; display: inline-block; }
  .title-logo.logo-dark { display: none; }
  :global([data-theme="dark"]) .title-logo.logo-light { display: none; }
  :global([data-theme="dark"]) .title-logo.logo-dark { display: inline-block; }
  .pitch { color: var(--text-muted); font-size: 14px; max-width: 48ch; }
  .project-link {
    font-family: var(--mono); font-size: 13px; color: var(--accent);
    display: inline-flex; align-items: center; gap: 8px; margin-top: 14px;
    padding: 9px 18px; border: 1px solid var(--border-strong); border-radius: 999px;
    transition: border-color .15s ease, background .15s ease, color .15s ease;
  }
  .project-card:hover .project-link { color: var(--accent); border-color: var(--accent); background: var(--accent-soft); }
  .thumb { width: 100%; height: 150px; background: linear-gradient(135deg, var(--accent-soft), var(--copper-soft)); border-radius: 4px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 11px; color: var(--text-muted); overflow: hidden; }
  .thumb.has-img { background: none; padding: 0; }
  .thumb.has-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 880px) {
    .project-card { grid-template-columns: 1fr; }
    .thumb { height: 180px; order: -1; }
  }
  @media (max-width: 480px) {
    .tl-item { grid-template-columns: 1fr; gap: 0; }
    /* Show the project number above each card instead of hiding it (no left rail in single column) */
    .tl-marker {
      display: block;
      padding-top: 0;
      margin-bottom: 10px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.1em;
    }
    .tl-marker::after { display: none; }
    .project-card { padding: 14px 12px; margin-bottom: 16px; }
    .thumb { height: 150px; }
    .project-card h3 { font-size: 14px; }
    .pitch { font-size: 12.5px; }
    .tag { font-size: 9px; padding: 2px 6px; }
    .tag-logo { width: 11px; height: 11px; }
    .project-link { font-size: 12.5px; }
    .thumb { height: 160px; font-size: 9px; }
  }
</style>
