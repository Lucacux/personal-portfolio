---
import FetchCard from "./FetchCard.astro";
---

<section class="hero-section">
  <!-- Full-width decorative dots, anchored to the section (not the centered wrap) -->
  <div class="dot-pattern fade-r hero-dots-l" aria-hidden="true"></div>
  <div class="dot-pattern fade-l hero-dots-r" aria-hidden="true"></div>

  <div class="wrap hero hero-enter">
    <div class="hero-text">
      <h1 class="name-line">Luca Lombardo</h1>
      <p class="eyebrow"><span class="dot"></span>IAM Provisioning Associate @ EY GDS — Linux, Networks &amp; Infra</p>
      <p class="tagline">I like understanding how things <span class="accent">actually work</span> — not just using them.</p>
      <p class="lead">
        Third-year Computer Engineering student at Universidad del Salvador, currently working as
        IAM Provisioning Associate at EY GDS. Experienced Linux user, firm believer in open-source software.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="#projects">View projects</a>
        <a class="btn ghost" href="/CV-LUCA-SANTIAGO-LOMBARDO.docx" download>Download CV</a>
      </div>
    </div>

    <div class="hero-card">
      <FetchCard />
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    isolation: isolate;
    overflow: clip;
  }
  .hero-dots-l { position: absolute; top: 16px; left: 0; z-index: -1; }
  .hero-dots-r { position: absolute; bottom: 24px; right: 0; z-index: -1; }

  .hero {
    padding: 72px 0 88px;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 64px;
    align-items: center;
  }
  /* minmax(0,...) is the key: lets grid columns shrink instead of overflowing */
  .hero-text { min-width: 0; }
  .hero-card { min-width: 0; }

  /* Name — pixel font, must wrap & never overflow */
  .name-line {
    font-family: "Nine By Five", "IBM Plex Mono", monospace;
    font-size: clamp(44px, 5.5vw + 14px, 88px);
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.01em;
    line-height: 1.04;
    margin-bottom: 22px;
    margin-left: clamp(4px, 1.5vw, 28px);
    overflow-wrap: break-word;
    word-break: break-word;
    max-width: 100%;
  }

  .eyebrow {
    font-size: clamp(13px, 0.5vw + 11px, 15px) !important;
    margin-bottom: 18px !important;
    font-weight: 500;
    overflow-wrap: break-word;
  }

  .tagline {
    font-size: clamp(22px, 1.6vw + 12px, 34px);
    font-weight: 600;
    line-height: 1.24;
    color: var(--text);
    margin-bottom: 20px;
    max-width: 22ch;
  }
  .tagline .accent { color: var(--accent); }

  .lead {
    font-size: clamp(14px, 0.5vw + 12px, 16.5px);
    color: var(--text-muted);
    max-width: 50ch;
    margin-bottom: clamp(20px, 2vw + 8px, 32px);
  }
  .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

  /* Entrance animations */
  .hero-enter .name-line { animation: nameReveal 1.2s cubic-bezier(0.25,1,0.5,1) 0.15s both; }
  .hero-enter .eyebrow   { animation: heroSlideUp 1s cubic-bezier(0.25,1,0.5,1) 0.4s both; }
  .hero-enter .tagline   { animation: heroSlideUp 1s cubic-bezier(0.25,1,0.5,1) 0.55s both; }
  .hero-enter .lead      { animation: heroSlideUp 1s cubic-bezier(0.25,1,0.5,1) 0.7s both; }
  .hero-enter .cta-row   { animation: heroSlideUp 1s cubic-bezier(0.25,1,0.5,1) 0.85s both; }
  .hero-enter .hero-card { animation: heroSlideUp 1.1s cubic-bezier(0.25,1,0.5,1) 0.6s both; }

  @keyframes heroSlideUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes nameReveal {
    from { opacity: 0; transform: translateY(50px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; padding: 44px 0 48px; gap: 36px; }
    .tagline { max-width: none; }
  }
  @media (max-width: 480px) {
    .hero { padding: 28px 0 32px; gap: 24px; }
    .name-line { margin-bottom: 12px; }
    .eyebrow { margin-bottom: 14px !important; }
    .cta-row { gap: 10px; }
    .cta-row .btn { padding: 10px 18px; font-size: 13px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-enter .name-line,
    .hero-enter .eyebrow,
    .hero-enter .tagline,
    .hero-enter .lead,
    .hero-enter .cta-row,
    .hero-enter .hero-card { animation: none; }
  }
</style>
