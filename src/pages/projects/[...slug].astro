  <script is:inline>
    (function () {
      function openDrawer(root) {
        if (!root) return;
        root.classList.add("open");
        root.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }
      function closeAll() {
        var open = document.querySelectorAll(".cf-drawer-root.open");
        for (var i = 0; i < open.length; i++) {
          open[i].classList.remove("open");
          open[i].setAttribute("aria-hidden", "true");
        }
        document.body.style.overflow = "";
      }
      document.addEventListener("click", function (e) {
        var trigger = e.target.closest("[data-drawer-open]");
        if (trigger) {
          e.preventDefault();
          closeAll();
          openDrawer(document.getElementById("drawer-" + trigger.getAttribute("data-drawer-open")));
        } else if (e.target.closest("[data-drawer-close]")) {
          closeAll();
        }
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeAll();
      });

      // Image lightbox: click any case-study figure to view it full-screen.
      var lb = document.getElementById("lightbox");
      var lbImg = document.getElementById("lightbox-img");
      function openLightbox(src, alt) {
        if (!lb || !lbImg) return;
        lbImg.src = src; lbImg.alt = alt || "";
        lb.classList.add("open"); lb.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }
      function closeLightbox() {
        if (!lb) return;
        lb.classList.remove("open"); lb.setAttribute("aria-hidden", "true");
        lbImg.src = "";
        if (!document.querySelector(".cf-drawer-root.open")) document.body.style.overflow = "";
      }
      document.addEventListener("click", function (e) {
        var fig = e.target.closest(".tline-figure img, .topology-figure img, .cf-figure img");
        if (fig) { openLightbox(fig.currentSrc || fig.src, fig.alt); return; }
        if (lb && lb.classList.contains("open") && (e.target === lb || e.target === lbImg || e.target.closest(".lightbox-close"))) {
          closeLightbox();
        }
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeLightbox();
      });
    })();
  </script>
</BaseLayout>

<style>
  .case-outer { position: relative; overflow: clip; width: 100%; }
