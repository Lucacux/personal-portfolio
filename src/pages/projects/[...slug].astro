---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import { homelabTimeline } from "../../data/homelabTimeline.ts";
import { openwrtTimeline } from "../../data/openwrtTimeline.ts";
import { discordBots } from "../../data/discordBots.ts";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Map project tags → their logo files (so tags show logo + label).
const logoModules = import.meta.glob("../../images/*", { eager: true, query: "?url", import: "default" }) as Record<string, string>;
function imgUrl(filename: string) {
  const match = Object.entries(logoModules).find(([path]) => path.endsWith("/" + filename));
  return match?.[1];
}
const tagLogos: Record<string, string | undefined> = {
  "Peppermint": imgUrl("peppermint-logo.svg"),
  "Ubuntu": imgUrl("ubuntu-original.svg"),
  "Debian": imgUrl("debian-original.svg"),
  "Arch Linux": imgUrl("archlinux-original.svg"),
  "Samba": imgUrl("samba-logo.svg"),
  "SSH": imgUrl("ssh-logo.svg"),
  "Docker": imgUrl("docker-original.svg"),
  "Jellyfin": imgUrl("jellyfin-logo.svg"),
  "OpenWrt": imgUrl("OpenWrt_Logo.svg"),
  "Firewall": imgUrl("firewall.svg"),
  "VLANs": imgUrl("router.svg"),
  "DNS-over-HTTPS": imgUrl("dns.svg"),
  "SQM / CAKE": imgUrl("qos.svg"),
  "zram": imgUrl("ram-memory.svg"),
  // Cloudflare suite (Tunnel + domain + WAF), shown tidily as a single tag.
  "Cloudflare": imgUrl("Cloudflare_Logo.svg"),
  // Discord bots stack. imgUrl() returns undefined for files not present yet,
  // so the tag simply shows its label until the SVG is dropped into src/images/.
  "Python": imgUrl("python-original.svg"),
  "discord.py": imgUrl("discord.svg"),
  "discord.js": imgUrl("discord.svg"),
  "Node.js": imgUrl("nodejs-original.svg"),
  "PostgreSQL": imgUrl("postgresql-original.svg"),
  "Ansible": imgUrl("ansible-original.svg"),
  "Dokploy": imgUrl("dokploy.svg"),
  "Dockerfile": imgUrl("dockerfile.svg"),
  "Playwright": imgUrl("playwright.svg"),
  "Selenium": imgUrl("selenium.svg"),
  "FFmpeg": imgUrl("ffmpeg.svg"),
  "systemd": imgUrl("systemd.svg"),
  "Wake-on-LAN": imgUrl("wol.svg"),
  "Ollama": imgUrl("ollama.svg"),
};
// Dark-mode variants for tags whose logo needs to swap by theme (light/dark).
const tagLogosDark: Record<string, string | undefined> = {
  "Dokploy": imgUrl("dokploy-dark.svg"),
  "Ollama": imgUrl("ollama-dark.svg"),
};

const all = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((p) => p.id === entry.id);
const prev = idx > 0 ? all[idx - 1] : null;

// The homelab and OpenWrt projects render as a visual timeline instead of plain prose.
const timelines: Record<string, typeof homelabTimeline> = {
  homelab: homelabTimeline,
  openwrt: openwrtTimeline,
};
const useTimeline = entry.id in timelines;
const timeline = timelines[entry.id] ?? [];

// The Discord bots project renders as a series of per-bot blocks (title, text, image, tech logos).
const showBots = entry.id === "discord-bots";

// Cloudflared explainer drawer (roadmap.sh-style) — only on the homelab case study.
const docModules = import.meta.glob("../../documentacion-cloudflared/*.svg", { eager: true, query: "?url", import: "default" }) as Record<string, string>;
function docUrl(filename: string) {
  const match = Object.entries(docModules).find(([path]) => path.endsWith("/" + filename));
  return match?.[1];
}
// Resolve a diagram from either the documentacion folder or the images folder.
function diagramUrl(filename: string) {
  return docUrl(filename) ?? imgUrl(filename);
}
const cfDiagram = docUrl("how-cloudflared-works.svg");
const cgnatDiagram = diagramUrl("CGNAT-explanation.svg");
const showCfDrawer = entry.id === "homelab";
// DoH explainer drawer (OpenWrt case study) — three-step visual comparison.
const showDohDrawer = entry.id === "openwrt";
const stdDnsDiagram = diagramUrl("Standard-DNS-Request.svg");
const dohReqDiagram = diagramUrl("DoH-Request.svg");
const dohIspDiagram = diagramUrl("Doh-ISP-perspective.svg");
const dohRepoUrl = "https://github.com/Lucacux/DNS-OVER-HTTPS-OpenWRT";
// Icon for the DoH drawer badge.
const dnsIcon = imgUrl("dns.svg");
// OpenWrt wordmark for the case-study title (light + dark variants).
const openwrtLogo = imgUrl("OpenWrt_Logo.svg");
const openwrtLogoDark = imgUrl("OpenWrt_Logo-dark.svg");
// Rich network-topology diagram, shown prominently on the OpenWrt case study.
const topologyDiagram = diagramUrl("My-Network-Topology.svg");
// Full homelab infrastructure diagram, shown prominently on the homelab case study.
const homelabDiagram = diagramUrl("My-Homelab-Infrastructure.svg");
// Cloudflare wordmark for the drawer badge (light + dark variants).
const cfLogo = imgUrl("Cloudflare_Logo.svg");
const cfLogoDark = imgUrl("Cloudflare_Logo-dark.svg");
// Router icon for the CGNAT drawer badge.
const routerIcon = imgUrl("router.svg");
// server-mbp drawer (homelab): the 2011 MacBook Pro node. Photos guarded — undefined if not present yet.
const archIcon = imgUrl("archlinux-original.svg");
const mbpPhoto = imgUrl("server-mbp.png");
const mbpServices = imgUrl("server-mbp-services.png");
// Google Docs icon for the resource row.
const gdocsIcon = imgUrl("Google_Docs_icon_(2026).svg");
// Downloadable setup guide (served from /public, works in dev and prod). Written in Spanish.
const cfDocUrl = "/docs/cloudflare-tunnel-ssh-guia.docx";
function timelineImg(filename?: string) {
  if (!filename) return undefined;
  const match = Object.entries(logoModules).find(([path]) => path.endsWith("/" + filename));
  return match?.[1];
}
// Bot artwork lives in src/imagenes-bots/ (Astro optimizes these at build).
const botArtModules = import.meta.glob("../../imagenes-bots/*", { eager: true, query: "?url", import: "default" }) as Record<string, string>;
function botArt(filename?: string) {
  if (!filename) return undefined;
  const match = Object.entries(botArtModules).find(([path]) => path.endsWith("/" + filename));
  return match?.[1];
}
const next = idx < all.length - 1 ? all[idx + 1] : null;
---

<BaseLayout title={`${entry.data.title} — Luca Lombardo`} description={entry.data.pitch}>
  <Nav />
  <div class="case-outer">
    <div class="dot-pattern fade-r" style="top:90px;left:0;"></div>
    <div class="dot-pattern fade-l" style="top:380px;right:0;"></div>
    <div class="dot-pattern fade-r" style="top:780px;left:0;"></div>
    <div class="dot-pattern fade-l" style="bottom:240px;right:0;"></div>
    <main class="wrap case-study">
    <a class="back-link" href="/#projects">← back to projects</a>

    <header class="case-head">
      <h1>
        {entry.id === "openwrt" ? (
          <span class="title-with-logo">
            <img class="title-logo logo-light" src={openwrtLogo} alt="OpenWrt" />
            <img class="title-logo logo-dark" src={openwrtLogoDark} alt="OpenWrt" />
            <span>router lab</span>
          </span>
        ) : entry.data.title}
      </h1>
      <p class="pitch">{entry.data.pitch}</p>
      <div class="tag-row">
        {entry.data.tags.map((t) => (
          <span class="tag">
            {tagLogos[t] && (tagLogosDark[t]
              ? <>
                  <img class="tag-logo logo-light" src={tagLogos[t]} alt="" loading="lazy" />
                  <img class="tag-logo logo-dark" src={tagLogosDark[t]} alt="" loading="lazy" />
                </>
              : <img class="tag-logo" src={tagLogos[t]} alt="" loading="lazy" />
            )}
            {t}
          </span>
        ))}
      </div>
      <div class="meta-row">
        {entry.data.date && <span>{entry.data.date}</span>}
        {entry.data.repoUrl && (
          <a href={entry.data.repoUrl} target="_blank" rel="noopener">view repo →</a>
        )}
        {entry.data.liveUrl && (
          <a href={entry.data.liveUrl} target="_blank" rel="noopener">live →</a>
        )}
      </div>
    </header>

    {entry.data.skills && entry.data.skills.length > 0 && (
      <div class="skills-box">
        <div class="skills-label">Skills practiced</div>
        <div class="skills-row">
          {entry.data.skills.map((s) => <span class="skill">{s}</span>)}
        </div>
      </div>
    )}

    {entry.id === "openwrt" && topologyDiagram && (
      <figure class="topology-figure">
        <img src={topologyDiagram} alt="My current home network topology: ISP router bridged to the OpenWrt gateway, VLAN-segmented servers, and the private LAN." loading="lazy" />
        <figcaption>My current network topology, end to end.</figcaption>
      </figure>
    )}

    {entry.id === "homelab" && homelabDiagram && (
      <figure class="topology-figure">
        <img src={homelabDiagram} alt="My homelab infrastructure: servers, the services each one runs, and how everything connects." loading="lazy" />
        <figcaption>My homelab infrastructure, end to end.</figcaption>
      </figure>
    )}

    {useTimeline ? (
      <div class="timeline-wrap">
        {timeline.map((t) => (
          <div class="tline-item">
            <span class={`tline-dot ${t.filled ? "filled" : ""}`}></span>
            <div class="tline-year">{t.year}</div>
            <h3 class="tline-title">{t.title}</h3>
            {timelineImg(t.logo) && (
              <div class="tline-logo">
                <img src={timelineImg(t.logo)} alt="" loading="lazy" />
              </div>
            )}
            {t.bodyHtml
              ? <p class="tline-body" set:html={t.bodyHtml} />
              : <p class="tline-body">{t.body}</p>}
            {timelineImg(t.image) && (
              <figure class="tline-figure">
                <img src={timelineImg(t.image)} alt={t.caption || t.title} loading="lazy" />
                {t.caption && <figcaption>{t.caption}</figcaption>}
              </figure>
            )}
            {t.repoUrl && (
              <a class="tline-repo-below" href={t.repoUrl} target="_blank" rel="noopener noreferrer">
                <Icon name="github" />{t.repoText || "View on GitHub"}
              </a>
            )}
          </div>
        ))}
      </div>
    ) : showBots ? (
      <div class="bots-wrap">
        {discordBots.map((b) => (
          <section class="bot-block">
            {botArt(b.image) && (
              <div class="bot-banner"><img src={botArt(b.image)} alt={b.title} loading="lazy" /></div>
            )}
            <h3 class="bot-title">{b.title}</h3>
            <div class="bot-grid">
              <div class="bot-text">
                <p>{b.body}</p>
                <div class="tag-row">
                  {b.tags.map((t) => (
                    <span class="tag">
                      {tagLogos[t] && (tagLogosDark[t]
                        ? <>
                            <img class="tag-logo logo-light" src={tagLogos[t]} alt="" loading="lazy" />
                            <img class="tag-logo logo-dark" src={tagLogosDark[t]} alt="" loading="lazy" />
                          </>
                        : <img class="tag-logo" src={tagLogos[t]} alt="" loading="lazy" />
                      )}
                      {t}
                    </span>
                  ))}
                </div>
              </div>
              <a class="bot-repo" href={`https://github.com/Lucacux/${b.repo}`} target="_blank" rel="noopener noreferrer" aria-label={`View ${b.repo} on GitHub`}>
                <span class="bot-repo-glow"></span>
                <span class="bot-repo-logos">
                  <span class="bot-repo-mark"><Icon name="github" /></span>
                  <span class="bot-repo-plus">+</span>
                  {timelineImg(b.lang) && <img class="bot-repo-lang" src={timelineImg(b.lang)} alt="" loading="lazy" />}
                </span>
                <span class="bot-repo-name"><span class="owner">Lucacux/</span>{b.repo}</span>
                <span class="bot-repo-cta">View on GitHub →</span>
              </a>
            </div>
          </section>
        ))}
      </div>
    ) : (
      <article class="prose">
        <Content />
      </article>
    )}

    <nav class={`prev-next ${(!next && !prev) ? "solo" : ""}`}>
      <a class="nav-btn" href="/">← Back to home</a>
      {next
        ? <a class="nav-btn" href={`/projects/${next.id}/`}>{next.data.title} →</a>
        : prev && <a class="nav-btn" href={`/projects/${prev.id}/`}>← {prev.data.title}</a>}
    </nav>
    </main>
  </div>

  {showCfDrawer && (
    <div class="cf-drawer-root" id="drawer-cf" aria-hidden="true">
      <div class="cf-backdrop" data-drawer-close></div>
      <aside class="cf-panel" role="dialog" aria-modal="true" aria-label="How Cloudflare Tunnel works">
        <header class="cf-panel-head">
          <span class="cf-badge-logo">
            <img class="logo-light" src={cfLogo} alt="Cloudflare" />
            <img class="logo-dark" src={cfLogoDark} alt="Cloudflare" />
          </span>
          <button class="cf-close" type="button" data-drawer-close aria-label="Close">✕</button>
        </header>
        <div class="cf-panel-body">
          <h2 class="cf-title">How Cloudflare Tunnel works</h2>
          <p class="cf-lead">
            My home server sits behind CGNAT. I do have a public IP — but it's shared with many other
            subscribers and my ISP controls its ports, so I can't open or forward inbound ports to my
            server. Cloudflare Tunnel gets around this with a lightweight
            <code>cloudflared</code> daemon that dials <em>out</em> from the server to Cloudflare's edge
            and holds a persistent connection open.
          </p>

          {cfDiagram && (
            <figure class="cf-figure">
              <img src={cfDiagram} alt="Diagram: cloudflared dials out to Cloudflare's edge, which routes a subdomain back down the tunnel to a CGNAT-bound server." loading="lazy" />
              <figcaption>How traffic reaches the server despite CGNAT.</figcaption>
            </figure>
          )}

          <h3 class="cf-h3">My setup, in short</h3>
          <p>
            A subdomain of my own domain is routed by Cloudflare back down that tunnel to a local
            service — no open inbound ports and no public IP required. I use it to reach the box over
            SSH (moved off port 22, key-only authentication) and to expose selected services such as
            Jellyfin on their own subdomains.
          </p>

          <h3 class="cf-h3">Setup guide</h3>
          <p class="cf-note">
            The complete step-by-step walkthrough I wrote — from creating the tunnel to the client's
            <code>~/.ssh/config</code> — is available to download (written in Spanish):
          </p>
          <div class="cf-resources">
            <div class="cf-res-head">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>
              Resources
            </div>
            <a class="cf-res-row" href={cfDocUrl} download="Cloudflare-Tunnel-SSH-Cloudflared-guia.docx">
              {gdocsIcon && <img class="cf-res-logo" src={gdocsIcon} alt="Document" />}
              <span class="cf-res-text">
                <span class="cf-res-label">Cloudflare Tunnel for SSH — full step-by-step guide</span>
                <span class="cf-res-sub">DOCX · Español</span>
              </span>
              <svg class="cf-res-ext" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <div class="cf-drawer-root" id="drawer-cgnat" aria-hidden="true">
      <div class="cf-backdrop" data-drawer-close></div>
      <aside class="cf-panel" role="dialog" aria-modal="true" aria-label="What is CGNAT">
        <header class="cf-panel-head">
          <span class="cf-badge">
            {routerIcon && <img class="cf-badge-icon" src={routerIcon} alt="" />}
            Networking
          </span>
          <button class="cf-close" type="button" data-drawer-close aria-label="Close">✕</button>
        </header>
        <div class="cf-panel-body">
          <h2 class="cf-title">What is CGNAT?</h2>
          <p class="cf-lead">
            CGNAT (Carrier-Grade NAT) is how many ISPs stretch a limited pool of public IPv4
            addresses across a lot of subscribers. Instead of giving each customer their own public
            IP, the provider adds a second layer of NAT inside its own network, so many households
            end up sharing a single public address.
          </p>

          {cgnatDiagram && (
            <figure class="cf-figure">
              <img src={cgnatDiagram} alt="Diagram: many subscribers sharing a single public IP behind the ISP's carrier-grade NAT." loading="lazy" />
              <figcaption>Many subscribers behind one shared public IP.</figcaption>
            </figure>
          )}

          <h3 class="cf-h3">Why it's a wall</h3>
          <p>
            You still have a public IP — but it's shared, and the ISP controls its ports. There's no
            port on that address that maps back to just your router, so inbound connections and
            port-forwarding simply don't work. That's why a home server can't be exposed the classic
            way, and why an <em>outbound</em> tunnel like Cloudflare Tunnel is needed instead.
          </p>
        </div>
      </aside>
    </div>

    <div class="cf-drawer-root" id="drawer-mbp" aria-hidden="true">
      <div class="cf-backdrop" data-drawer-close></div>
      <aside class="cf-panel" role="dialog" aria-modal="true" aria-label="The high-agility node — a 2011 MacBook Pro">
        <header class="cf-panel-head">
          <span class="cf-badge">
            {archIcon && <img class="cf-badge-icon" src={archIcon} alt="" />}
            Homelab node
          </span>
          <button class="cf-close" type="button" data-drawer-close aria-label="Close">✕</button>
        </header>
        <div class="cf-panel-body">
          <h2 class="cf-title">The high-agility node</h2>
          <p class="cf-lead">
            Nothing exotic — a 13-inch MacBook Pro from 2011, a dual-core i5 with 10 GiB of RAM.
            It just happens to be the most capable machine in the homelab (everything else is older
            and slower), so it became the node I lean on when something needs a bit more than the
            vintage servers can give. macOS is gone; it runs Arch Linux (linux-lts), headless and
            always on.
          </p>

          {mbpPhoto && (
            <figure class="cf-figure cf-photo">
              <img src={mbpPhoto} alt="The 2011 MacBook Pro running Arch Linux as a homelab node." loading="lazy" />
              <figcaption>server-mbp — a 2011 MacBook Pro running Arch Linux.</figcaption>
            </figure>
          )}

          <h3 class="cf-h3">What it runs</h3>
          <p>
            It's the homelab's control node. Ansible runs here to push fleet-wide updates (triggered
            from a Discord bot), and Dokploy handles CI/CD, building the Dockerfiles for both container
            and bare-metal deploys. On top of that it hosts Ollama serving Qwen 2.5 (the local model
            behind Thinky-AI), an offline self-hosted Wikipedia, and a PostgreSQL + Redis stack in
            Docker Compose for a collaborative database project.
          </p>

          {mbpServices && (
            <figure class="cf-figure cf-photo">
              <img src={mbpServices} alt="Some of the services running on server-mbp." loading="lazy" />
              <figcaption>Some of the services on server-mbp.</figcaption>
            </figure>
          )}
        </div>
      </aside>
    </div>
  )}

  {showDohDrawer && (
    <div class="cf-drawer-root" id="drawer-doh" aria-hidden="true">
      <div class="cf-backdrop" data-drawer-close></div>
      <aside class="cf-panel" role="dialog" aria-modal="true" aria-label="How my DNS stays private">
        <header class="cf-panel-head">
          <span class="cf-badge">
            {dnsIcon && <img class="cf-badge-icon" src={dnsIcon} alt="" />}
            DNS Privacy
          </span>
          <button class="cf-close" type="button" data-drawer-close aria-label="Close">✕</button>
        </header>
        <div class="cf-panel-body">
          <h2 class="cf-title">How my DNS stays private</h2>
          <p class="cf-lead">
            By default, every "where does this domain live?" lookup leaves the network in plain text,
            and the ISP reads all of it. My OpenWrt router runs its own DNS and forwards it upstream
            over an encrypted channel — here's the difference, in three steps.
          </p>

          <h3 class="cf-h3">1 · Standard DNS — the ISP sees everything</h3>
          <p>
            A normal DNS query is sent in the clear. Even if the page itself is HTTPS, the lookup that
            says "I'm about to visit youtube.com" travels in plaintext straight through the ISP's
            resolver, which can log, profile, or tamper with it.
          </p>
          {stdDnsDiagram && (
            <figure class="cf-figure">
              <img src={stdDnsDiagram} alt="A plaintext DNS query for youtube.com passing readable through the ISP's DNS server." loading="lazy" />
              <figcaption>Plaintext DNS — the ISP reads every lookup.</figcaption>
            </figure>
          )}

          <h3 class="cf-h3 cf-h3--doh">2 · DNS over HTTPS — encrypted upstream</h3>
          <p>
            Local devices still ask the OpenWrt router on port 53 (forced by a DNS-LOCK rule). The
            router then resolves the query upstream to a public resolver over HTTPS on port 443 —
            wrapped in TLS — and hands the answer back to the client on the LAN.
          </p>
          {dohReqDiagram && (
            <figure class="cf-figure">
              <img src={dohReqDiagram} alt="OpenWrt receives a local DNS query on port 53 and resolves it upstream to Cloudflare over encrypted HTTPS on port 443." loading="lazy" />
              <figcaption>OpenWrt resolves upstream over encrypted HTTPS.</figcaption>
            </figure>
          )}

          <h3 class="cf-h3 cf-h3--doh">3 · What the ISP actually sees</h3>
          <p>
            From the ISP's side there's no readable query left — just a TLS session between my router
            and the resolver, carrying opaque "Application Data". They can tell I'm talking to a DNS
            provider, but not what I'm asking.
          </p>
          {dohIspDiagram && (
            <figure class="cf-figure">
              <img src={dohIspDiagram} alt="From the ISP's perspective, only encrypted TLS application data flows between OpenWrt and the resolver." loading="lazy" />
              <figcaption>To the ISP, it's just encrypted TLS bytes.</figcaption>
            </figure>
          )}

          <h3 class="cf-h3">Resources</h3>
          <div class="cf-resources">
            <div class="cf-res-head">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>
              Resources
            </div>
            <a class="cf-res-row" href={dohRepoUrl} target="_blank" rel="noopener noreferrer">
